/*
 * Nextflow config for Visium-HD-like spatial transcriptomics FASTQ simulation
 * DSL2, -resume compatible, seed-controlled
 */

params {
    // Randomness
    seed             = 42

    // Sequencing depth
    total_reads      = 50_000_000

    // Barcode / UMI structure
    barcode_length   = 36
    umi_length       = 10

    // ── Barcode error model (two-stage) ──────────────────────────────────────
    //
    // Stage 1 – Array synthesis errors (applied ONCE per spot).
    // Models errors introduced during printing/synthesis of the spatial array.
    // All reads from the same spot share the same synthesis-mutated barcode.
    // Values based on literature estimates for in-situ synthesis fidelity.
    synth_sub_rate = 0.03
    synth_ins_rate = 0.04
    synth_del_rate = 0.14

    // Stage 2 – Sequencing errors (applied independently per read).
    // Models base-calling errors on Illumina after PCR amplification.
    // These are ~10-100× lower than synthesis errors.
    seq_sub_rate = 0.001
    seq_ins_rate = 0.0001
    seq_del_rate = 0.0001

    // cDNA simulation
    reference_fasta  = "${projectDir}/data/reference/gencode.vM33.transcripts.fa"
    read_length_r1   = 50
    read_length_r2   = 100
    use_art          = false

    // Spatial simulation
    n_genes          = 5000      // number of genes to sample from H5 (or use in fallback)
    n_spots          = 100000   // number of spots to simulate
    feature_h5       = null     // Optional: path to Visium HD feature_slice.h5

    // Genes guaranteed to be included regardless of random sampling.
    // Comma-separated gene symbols (case-sensitive, must match Visium HD feature names).
    // These are pinned first; the remaining n_genes slots are filled by stratified sampling.
    // NOTE: only genes present in /feature_slices of the H5 (i.e. with non-zero expression)
    // can be pinned. Genes absent from the H5 are skipped with a warning.
    // Verified present in Visium_HD_Mouse_Brain_Fresh_Frozen_feature_slice.h5:
    //   Absent (zero expression, cannot simulate): Reln, Cux1, Cux2, Rorb, Prox1, Grik4, Penk
    //   Very sparse (46 UMIs total):               Drd2
    required_genes   = "Bcl11b,Tbr1,Calb1,Wfs1,Pcp4,Bok,Drd1,Drd2,Pdyn"

    // PCR duplication model
    pcr_enable       = true     // simulate PCR duplicate families
    pcr_family_dist  = "geometric" // distribution for family size: "geometric" or "const"
    pcr_geom_p       = 0.5      // geometric dist. parameter p (mean family = 1/p)
    pcr_max_family   = 20       // cap on family size

    // Parallelisation
    sim_shards       = 8        // split molecules into this many parallel shards

    // Output
    out_dir          = "${projectDir}/results/M33/set50M100k5kgenes_trans"
}

// Process default settings
process {
    maxRetries    = 1
    errorStrategy = 'retry'
    shell         = ['/bin/bash', '-euo', 'pipefail']

    // Published outputs (final results only)
    withName: 'RUN_SRT_SIM|PREPARE_TRANSCRIPT_ABUNDANCE|FINALIZE_OUTPUTS' {
        publishDir = [path: "${params.out_dir}", mode: 'copy']
    }

    // Per-process resource hints (used by schedulers; ignored by local executor)
    withName: 'RUN_SRT_SIM' {
        cpus   = 1
        memory = '30 GB'
        time   = '4 h'
    }
    withName: 'PREPARE_TRANSCRIPT_ABUNDANCE' {
        cpus   = 1
        memory = '30 GB'
        time   = '2 h'
    }
    withName: 'SHARD_MOLECULES' {
        cpus   = 1
        memory = '4 GB'
        time   = '30 min'
    }
    // Sharded processes – one job per shard, runs in parallel
    withName: 'SIMULATE_CDNA_READS_SRT' {
        cpus   = 1
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'ATTACH_SPATIAL_BARCODES' {
        cpus   = 1
        memory = '4 GB'
        time   = '1 h'
    }
    withName: 'EXPAND_PCR_DUPLICATES' {
        cpus   = 1
        memory = '4 GB'
        time   = '2 h'
    }
    withName: 'MERGE_SHARDS' {
        cpus   = 1
        memory = '8 GB'
        time   = '1 h'
    }
    withName: 'FINALIZE_OUTPUTS' {
        cpus   = 1
        memory = '4 GB'
        time   = '30 min'
    }
}

// Profiles
profiles {
    local {
        process.executor = 'local'
        process.maxForks = 4
    }
    conda {
        process.executor = 'local'
        process.maxForks = 4
        process.conda    = "${projectDir}/environment.yml"
    }
    conda_named {
        process.executor = 'local'
        process.maxForks = 10   // match ppn in SimJob.sh
        process.conda    = 'stdata_sim'
    }
    singularity {
        process.executor       = 'local'
        process.maxForks       = 4
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = "${projectDir}/stdata_sim.sif"
    }
    docker {
        docker.enabled    = true
        process.container = 'python:3.10-slim'
    }
}

// Add bin/ to PATH so scripts are found without full path
env {
    PATH = "${projectDir}/bin:${System.getenv('PATH')}"
}
